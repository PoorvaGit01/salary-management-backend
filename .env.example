# Copy to .env and adjust for your machine: cp .env.example .env
# dotenv loads .env in development and test (see Gemfile).

# --- PostgreSQL (used when DATABASE_URL is not set) ---
PGHOST=localhost
PGPORT=5432
# PGUSER=postgres
PGPASSWORD=

# App database names (optional; defaults match README)
# DATABASE_NAME=salary_management_backend_development
# DATABASE_TEST_NAME=salary_management_backend_test

# Single-URL connection (optional; overrides PG* for development/test primary DB only)
# DATABASE_URL=postgres://postgres@localhost:5432/salary_management_backend_development

# Production primary DB is often set from the host (e.g. DATABASE_URL). Cache, queue, and
# cable DBs still use PGHOST / PGUSER / PGPASSWORD with separate names:
# DATABASE_CACHE_NAME=salary_management_backend_production_cache
# DATABASE_QUEUE_NAME=salary_management_backend_production_queue
# DATABASE_CABLE_NAME=salary_management_backend_production_cable
